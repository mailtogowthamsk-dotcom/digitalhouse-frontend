# .env              → used by production builds (`npm run build`)
# .env.development  → used by local (`npm run dev`) and overrides .env
#
# Local (recommended — Vite proxies to backend on :4000):
#   VITE_API_BASE=/digitalhouse/backend
# Local direct:
#   VITE_API_BASE=http://localhost:4000
# Production:
#   VITE_API_BASE=https://www.infosensetechnologies.com/digitalhouse/backend
VITE_API_BASE=https://www.infosensetechnologies.com/digitalhouse/backend
VITE_ADMIN_KEY=your-admin-key-here
